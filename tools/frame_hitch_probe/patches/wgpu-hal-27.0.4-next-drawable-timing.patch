+#[cfg(target_os = "macos")]
+#[derive(Debug, Default)]
+struct WindowPresentationState {
+    visible: Option<bool>,
+    occlusion_state: Option<usize>,
+    occlusion_visible: Option<bool>,
+}
+
+#[cfg(target_os = "macos")]
+unsafe fn window_presentation_state(
+    render_layer: &metal::MetalLayerRef,
+) -> WindowPresentationState {
+    let mut current_layer = render_layer.as_ptr().cast::<Object>();
+    while !current_layer.is_null() {
+        let delegate: *mut Object = unsafe { msg_send![current_layer, delegate] };
+        if !delegate.is_null() {
+            let responds_to_window: BOOL =
+                unsafe { msg_send![delegate, respondsToSelector: sel!(window)] };
+            if responds_to_window != NO {
+                let window: *mut Object = unsafe { msg_send![delegate, window] };
+                if !window.is_null() {
+                    let visible: BOOL = unsafe { msg_send![window, isVisible] };
+                    let occlusion_state: usize =
+                        unsafe { msg_send![window, occlusionState] };
+                    return WindowPresentationState {
+                        visible: Some(visible != NO),
+                        occlusion_state: Some(occlusion_state),
+                        occlusion_visible: Some((occlusion_state & (1 << 1)) != 0),
+                    };
+                }
+            }
+        }
+        current_layer = unsafe { msg_send![current_layer, superlayer] };
+    }
+    WindowPresentationState::default()
+}
